<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#4D9B70"
    android:id="@+id/main"

    tools:context=".Doctor_Home">



    <!-- Heading "Doctor Home" -->
    <TextView
        android:layout_width="match_parent"
        android:layout_marginVertical="20dp"
        android:layout_marginHorizontal="20dp"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:text="DOCTOR HOME"
        android:textSize="50sp"
        android:textColor="#F5F5DC"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Profile Section -->


    <!-- Main Scrollable Content -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginTop="100dp">

        <!-- Profile Section -->
        <RelativeLayout
            android:id="@+id/drprofile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5DC"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/logoProfile"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/drprf" />

            <TextView
                android:id="@+id/textProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="104dp"
                android:layout_alignParentTop="true"
                android:text="Doctor Profile"
                android:textSize="18sp"
                android:textColor="#046F0E"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textProfileSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="104dp"
                android:layout_below="@id/textProfile"
                android:text="View your profile information"
                android:textSize="14sp"
                android:textColor="#1A9E1E" />

        </RelativeLayout>

        <!-- Booking Section -->
        <RelativeLayout
            android:id="@+id/bookingid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5DC"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/logoBooking"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"

                android:src="@drawable/bkns" />

            <TextView
                android:id="@+id/textBooking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="104dp"
                android:layout_alignParentTop="true"
                android:text="Bookings"
                android:textSize="18sp"
                android:textColor="#046F0E"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textBookingSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="104dp"
                android:layout_below="@id/textBooking"
                android:text="Check your upcoming bookings"
                android:textSize="14sp"
                android:textColor="#1A9E1E" />

        </RelativeLayout>

        <!-- Approved Booking Section -->
        <RelativeLayout
            android:id="@+id/apbk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5DC"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/logoApprovedBooking"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/appbk" />

            <TextView
                android:id="@+id/textApprovedBooking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="104dp"
                android:layout_alignParentTop="true"
                android:text="Approved Bookings"
                android:textSize="18sp"
                android:textColor="#046F0E"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textApprovedBookingSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textApprovedBooking"
                android:layout_marginStart="104dp"
                android:layout_marginTop="0dp"
                android:text="See the approved appointments"
                android:textColor="#1A9E1E"
                android:textSize="14sp" />

        </RelativeLayout>

        <!-- Patient List Section -->
        <RelativeLayout
            android:id="@+id/patientlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F5F5DC"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/logoPatientList"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ptl" />

            <TextView
                android:id="@+id/textPatientList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="104dp"
                android:layout_alignParentTop="true"
                android:text="Patient List"
                android:textSize="18sp"
                android:textColor="#046F0E"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textPatientListSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="104dp"
                android:layout_below="@id/textPatientList"
                android:text="View all registered patients"
                android:textSize="14sp"
                android:textColor="#1A9E1E" />

        </RelativeLayout>

        <ViewFlipper
            android:id="@+id/myflipper"
            android:layout_width="380dp"
            android:layout_height="180dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            />


    </androidx.appcompat.widget.LinearLayoutCompat>



</RelativeLayout>