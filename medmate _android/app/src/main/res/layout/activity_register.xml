<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Register"
    android:background="#FFF8E7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Register"
        android:textSize="30dp"
        android:gravity="center"
        android:layout_marginTop="100dp"
        android:textStyle="bold"
        android:textColor="@color/green"
        >
    </TextView>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingHorizontal="20dp"
            app:counterTextColor="@color/green"
            app:boxStrokeColor="@color/green"

            >
            <EditText
                android:id="@+id/registername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Name"
                android:layout_marginTop="20dp"
                android:textCursorDrawable="@color/green"
                android:textColor="@color/green"

                >

            </EditText>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingHorizontal="20dp"
            app:boxStrokeColor="@color/green"
            >
            <EditText
                android:id="@+id/registeremail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:layout_marginTop="20dp"
                android:textCursorDrawable="@color/green"
                android:textColor="@color/green">

            </EditText>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:paddingHorizontal="20dp"
            app:boxStrokeColor="@color/green"

            >
   <EditText
       android:id="@+id/registermobilenumber"
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:hint="Mobile Number"
       android:layout_marginTop="20dp"
       android:textCursorDrawable="@color/green"
       android:textColor="@color/green">

   </EditText>
        </com.google.android.material.textfield.TextInputLayout>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:passwordToggleEnabled="true"
            android:paddingHorizontal="20dp"
            app:boxStrokeColor="@color/green"
            >
            <EditText
                android:id="@+id/registercreatepassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Create Password"
                android:inputType="textPassword"
                android:textCursorDrawable="@color/green"
                android:textColor="@color/green"
                >

            </EditText></com.google.android.material.textfield.TextInputLayout>
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:passwordToggleEnabled="true"
        android:paddingHorizontal="20dp"
        app:boxStrokeColor="@color/green"
        >
        <EditText
            android:id="@+id/registerconfirmpassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirm Password"
            android:inputType="textPassword"
            android:textCursorDrawable="@color/green"
            android:textColor="@color/green"
            >

        </EditText></com.google.android.material.textfield.TextInputLayout>
        <Button
            android:id="@+id/registersubmitbutton"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:text="Submit"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:backgroundTint="@color/green"
            android:textColor="@color/white"

            >




        </Button>
        <TextView
            android:id="@+id/registeralreadyaccount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Already have account?"
            android:gravity="center"
            android:textSize="20dp"
            android:layout_marginTop="10dp"
            android:textStyle="bold"
            android:textColor="@color/green"

            ></TextView>






</LinearLayout>

</RelativeLayout>
