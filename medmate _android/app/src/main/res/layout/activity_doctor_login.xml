<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="950dp"
    tools:context=".Login"
    android:background="#FFF8E7">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <ImageView
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/drlogo"
                android:layout_gravity="center"

                />

            <TextView
                android:id="@+id/drloginbutton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textSize="50dp"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/green">

            </TextView>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="20dp"
                app:boxStrokeColor="@color/green"
                >
                <EditText
                    android:id="@+id/drloginemail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email"
                    android:layout_marginTop="50dp"
                    android:textCursorDrawable="@color/green"
                    android:textColor="@color/green">

                </EditText>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                app:passwordToggleEnabled="true"
                android:paddingHorizontal="20dp"
                app:boxStrokeColor="@color/green"
                >
                <EditText
                    android:id="@+id/drloginpassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:layout_marginTop="40dp"
                    android:textCursorDrawable="@color/green"
                    android:textColor="@color/green"
                    >

                </EditText></com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/drlb"
                android:layout_width="100dp"
                android:layout_height="35dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:backgroundTint="@color/green"
                android:text="Log in"
                android:textColor="#FFF8E7">

            </Button>

            <TextView
                android:id="@+id/drloginforgotbutton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Forgotten password?"
                android:textSize="20dp"
                android:textStyle="bold"
                android:textColor="@color/green">

            </TextView>

            <Button
                android:id="@+id/drzlogincreatebutton"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:text="Create new account"
                android:backgroundTint="@color/green"

                android:layout_gravity="center"
                android:layout_marginTop="70dp"
                android:textColor="#FFF8E7">

            </Button>
        </LinearLayout>
    </RelativeLayout>

</ScrollView>